# SecureVu Configuration Template
# Rename this to .env and fill in the values

# --- Backend Auth ---
SECRET_KEY=b38d38e8f8a846f8820c74f5d6f3b4e2

# --- Redis ---
REDIS_HOST=localhost

# --- Webhooks (rules.py POSTs JSON for each alert) ---
# Single URL or comma-separated list
