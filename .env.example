# WEBHOOK_URLS=https://hooks.example.com/a,https://hooks.example.com/b

# --- Alert clips (same path as pipeline/clip_buffer.py) ---
# CLIP_DIR=storage/clips

# --- Telegram Notifications ---
# Get token from @BotFather on Telegram
